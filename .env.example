# Nomor WhatsApp tujuan order (format internasional tanpa "+", contoh: 6281234567890)
# WAJIB di-set di production. Format: 62XXXXXXXXXX (8-15 digit, tidak boleh diawali 0).
NEXT_PUBLIC_WHATSAPP_NUMBER=6281234567890

# Kredensial admin dashboard (Demo Local Admin).
# Saat ini auth hanya cek pasangan email/password lewat API route + simpan
# session di localStorage. Untuk production, ganti dengan auth provider proper
# (NextAuth, Clerk, Firebase/Supabase Auth) sebelum dipakai sungguhan.
ADMIN_EMAIL=admin@mushida.id
ADMIN_PASSWORD=changeme123

# URL produksi situs (untuk SEO & metadata).
NEXT_PUBLIC_SITE_URL=https://mushida.vercel.app

# (Opsional) Konfigurasi Supabase — biarkan kosong selama belum migrasi DB.
# Saat di-set, repository factory akan mengarah ke Supabase implementation.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
