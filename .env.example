# Nomor WhatsApp tujuan order (format internasional tanpa "+", contoh: 6285713254800)
# WAJIB di-set di production. Format: 62XXXXXXXXXX (8-15 digit, tidak boleh diawali 0).
NEXT_PUBLIC_WHATSAPP_NUMBER=6285713254800

# Email admin yang ditampilkan / dipakai sebagai placeholder login.
# Authentication sebenarnya pakai Supabase Auth, jadi password TIDAK
# dikonfigurasi via env. Buat user di Supabase Auth UI lalu daftarkan
# user.id ke tabel `admin_users`.
ADMIN_EMAIL=admin@mushida.me

# URL produksi situs (untuk SEO & metadata).
NEXT_PUBLIC_SITE_URL=https://mushida-craft.vercel.app

# Supabase credentials (WAJIB untuk admin & data produk).
# Ambil dari Supabase Dashboard → Settings → API.
# - URL = "Project URL"
# - Publishable key = "anon public" key (aman dipakai di client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Sosial media (opsional). Kalau kosong, fallback ke default di
# src/config/site.ts (https://instagram.com/mushida.id, https://facebook.com/mushida.id).
# Set di sini kalau handle final berbeda dari default.
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
